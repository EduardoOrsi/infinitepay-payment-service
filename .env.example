# Banco de dados
# Local: DATABASE_URL=file:sqlite.db
# Produção (Turso): DATABASE_URL=libsql://<seu-banco>.turso.io
DATABASE_URL=file:sqlite.db
TURSO_AUTH_TOKEN= # obrigatório em produção — token do Turso

INFINITEPAY_API_URL=https://api.checkout.infinitepay.io  # endpoint da API InfinitePay
INFINITEPAY_HANDLE= # obrigatório — sua Infinite Tag, sem o símbolo $
INFINITEPAY_WEBHOOK_URL= # URL pública deste servidor para receber webhooks da InfinitePay (opcional por enquanto)

# Sessão
PAYMENT_SESSION_EXPIRY_MINUTES=30
